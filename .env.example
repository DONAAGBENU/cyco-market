APP_NAME="CYCO MARKET"
APP_ENV=local                        # production en déploiement
APP_KEY=                             # générer avec: php artisan key:generate
APP_DEBUG=true                       # false en production
APP_URL=http://localhost             # https://cyco-market-production-9258.up.railway.app en production

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de données — en local, renseigner manuellement
# En production sur Railway, utiliser les variables de service MySQL :
#   DB_HOST=${{ MySQL.PGHOST }}
#   DB_PORT=${{ MySQL.PGPORT }}
#   DB_DATABASE=${{ MySQL.MYSQLDATABASE }}
#   DB_USERNAME=${{ MySQL.MYSQLUSER }}
#   DB_PASSWORD=${{ MySQL.MYSQLPASSWORD }}
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cyco_market
DB_USERNAME=root
DB_PASSWORD=

# Session configuration
SESSION_DRIVER=cookie                # cookie en production (pas de DB requise)
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_DRIVER=file

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="CYCO MARKET"

VITE_APP_NAME="CYCO MARKET"